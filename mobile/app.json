{
  "expo": {
    "name": "Laborator Emanuela",
    "slug": "laborator-emanuela",
    "scheme": "laboratoremanuela",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F2"
    },
    "sdkVersion": "51.0.0",
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "bundleIdentifier": "ro.laboratoremanuela.app",
      "buildNumber": "1",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "Permite aplicației Laborator Emanuela să se conecteze la serverul local de dezvoltare."
      }
    },
    "android": {
      "package": "ro.laboratoremanuela.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFF8F2"
      }
    }
  }
}
